*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
scroll-behavior:smooth;
}

body{
background:#0f172a;
color:white;
}

header{
background:#111827;
padding:15px 5%;
position:sticky;
top:0;
z-index:1000;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
}

nav ul{
display:flex;
list-style:none;
gap:20px;
}

nav ul li a{
color:white;
text-decoration:none;
font-weight:bold;
}

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
background:linear-gradient(
rgba(0,0,0,.6),
rgba(0,0,0,.6)
),
url("https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200");
background-size:cover;
background-position:center;
}

.hero h2{
font-size:3rem;
margin-bottom:15px;
}

.hero p{
font-size:1.2rem;
margin-bottom:20px;
}

.btn{
background:#f59e0b;
padding:12px 25px;
border-radius:10px;
color:white;
text-decoration:none;
font-weight:bold;
}

section{
padding:70px 5%;
}

h2{
text-align:center;
margin-bottom:30px;
}

.room-card{
background:#1e293b;
padding:25px;
border-radius:15px;
margin:15px 0;
transition:.3s;
}

.room-card:hover{
transform:translateY(-5px);
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
}

.gallery img{
width:100%;
height:250px;
object-fit:cover;
border-radius:15px;
}

form{
max-width:500px;
margin:auto;
display:flex;
flex-direction:column;
gap:15px;
}

form input,
form select{
padding:15px;
border:none;
border-radius:10px;
}

form button{
padding:15px;
background:#f59e0b;
border:none;
color:white;
font-size:18px;
border-radius:10px;
cursor:pointer;
}

#contact{
text-align:center;
background:#111827;
}

@media(max-width:768px){

nav{
flex-direction:column;
gap:15px;
}

nav ul{
flex-wrap:wrap;
justify-content:center;
}

.hero h2{
font-size:2rem;
}

}
